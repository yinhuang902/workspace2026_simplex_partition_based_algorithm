# After existing bounder init (line 66):
self.lower_bounder = self._params._lower_bounder(self._params._lb_solver)

# If LP relaxation enabled, wrap in CompositeLowerBounder
if self._params._use_lp_relaxation:
    from snoglode.bounders.composite_lower_bounder import CompositeLowerBounder
    self.lower_bounder = CompositeLowerBounder(
        existing_bounder=self.lower_bounder,
