# New method:
def enable_lp_relaxation(self, max_oa_iters: int = 20) -> None:
    """
    Enable Julia-style LP relaxation lower bound.
    When enabled, each node computes: LB = max(existing_lb, lp_relaxation_lb)
    """
    self._use_lp_relaxation = True
    self._lp_relax_max_oa_iters = max_oa_iters
