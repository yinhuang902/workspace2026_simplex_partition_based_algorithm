#### Changes to `dispatch_lb_solve` (lines 283-304)

```python
def dispatch_lb_solve(self, current_node: Node) -> None:
    self.logger.lb_start()
    
    # If composite bounder, pass current_UB
    if self._params._use_lp_relaxation:
        self.logger.lp_relax_start()
        self.lower_bounder.solve(
            subproblems=self.subproblems,
            node=current_node,
            current_UB=self.tree.metrics.ub
        )
        self.logger.lp_relax_stop()
        
        # Pass LP diagnostics to logger
        if current_node.lb_problem.lp_relax_diagnostics is not None:
            self.logger.set_lp_relax_diagnostics(
                current_node.lb_problem.lp_relax_diagnostics
            )
    else:
        self.lower_bounder.solve(
            subproblems=self.subproblems,
            node=current_node
        )
    
    self.logger.lb_stop()
    
    # MPI sync (unchanged)
    MPI.COMM_WORLD.barrier()
    current_node.lb_problem.feasible = \
        MPI.COMM_WORLD.allreduce(current_node.lb_problem.feasible, op=MPI.PROD)
    current_node.lb_problem.objective = \
        MPI.COMM_WORLD.allreduce(current_node.lb_problem.objective, op=MPI.SUM)
```

#### Changes to `display_status` (lines 442-503)

Add an `LPR` column to the terminal output when LP relaxation is active:

```python
# In display_status, if LP relaxation is active:
if self._params._use_lp_relaxation and current_node.lb_problem.lp_relax_diagnostics:
    d = current_node.lb_problem.lp_relax_diagnostics
    # Add to outputs list:
    outputs.append(d["lb_source"][:3])  # "lp_" or "exi"
    # Add to header list:
    header.append("LB Src")
```

