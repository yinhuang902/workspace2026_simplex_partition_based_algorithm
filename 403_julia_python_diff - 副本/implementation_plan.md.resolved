### [MODIFY] `snoglode/utils/logging.py`

#### Changes to `IterLogger`

```python
class IterLogger():
    def __init__(self, ...):
        # ... existing fields ...
        
        # NEW: LP relaxation timing
        self.lp_relax = np.zeros(2)          # [start, stop]
        self.total_lp_relax = 0
        
        # NEW: Per-iteration LP relaxation diagnostics (set from node)
        self._iter_lp_diag = None
    
    # NEW timing methods
    def lp_relax_start(self):
        self.lp_relax[0] = time.perf_counter()
    
    def lp_relax_stop(self):
        self.lp_relax[1] = time.perf_counter()
        self.total_lp_relax += self.lp_relax[1] - self.lp_relax[0]
    
    # NEW: accept diagnostics dict from the current node
    def set_lp_relax_diagnostics(self, diagnostics: dict):
        self._iter_lp_diag = diagnostics
    
    def update(self):
        # ... existing LB/CG/UB/Bound/Branch lines ...
        
        # NEW: Write LP relaxation timing
        if self._iter_lp_diag is not None:
            lp_start = round(...)
            lp_end = round(...)
            if rank == 0:
                self.logfile.write(f"LP_Relax,{lp_start},{lp_end},\n")
                d = self._iter_lp_diag
                self.logfile.write(
                    f"LP_Relax_Diag,"
                    f"existing_lb={d['existing_lb']:.8g},"
                    f"lp_relax_lb={d['lp_relax_lb']:.8g},"
                    f"final_lb={d['final_lb']:.8g},"
                    f"source={d['lb_source']},"
                    f"feasible={d['lp_relax_feasible']},"
                    f"oa_rounds={d['n_oa_rounds']},"
                    f"oa_cuts={d['n_oa_cuts']},"
                    f"abb_cuts={d['n_abb_cuts']}\n"
                )
        
        # Reset per-iter state
        self._iter_lp_diag = None
        self.lp_relax.fill(0)
        # ... existing resets ...
    
    def complete(self):
        # ... existing summary ...
        
        # NEW: Add LP relaxation time to summary
        if rank == 0:
            self.logfile.write(f"Total time spent on LP relaxation: {round(self.total_lp_relax, 4)}s\n")
            self.logfile.write(f"Percent time spent on LP relaxation: {round(self.total_lp_relax*100/self.snoglode_total, 4)}%\n")
```

